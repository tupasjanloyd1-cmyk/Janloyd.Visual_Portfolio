<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Janloyd Visual — Minimalist Futuristic Curation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,300&family=Inter:wght@100;300;600&display=swap" rel="stylesheet">
<style>
  :root {
    --sage-glow: #8A9A5B;
    --bg-black: #080908;
    --glass-white: rgba(255, 255, 255, 0.03);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --text-linen: #F5F5DC;
    --text-muted: #888a84;
    --font-sans: 'Inter', system-ui, sans-serif;
    --font-serif: 'Cormorant Garamond', serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background-color: var(--bg-black);
    color: var(--text-linen);
    font-family: var(--font-sans);
    line-height: 1.6;
    overflow-x: hidden;
    letter-spacing: -0.01em;
  }

  /* ── MINIMALIST AURA ── */
  .aura {
    position: fixed;
    top: -10%; right: -10%;
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, rgba(138, 154, 91, 0.05) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  /* ── NAVIGATION ── */
  nav {
    position: fixed;
    top: 0; width: 100%;
    padding: 2rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    z-index: 1000;
    background: linear-gradient(to bottom, var(--bg-black), transparent);
    backdrop-filter: blur(10px);
  }

  .nav-logo img { height: 30px; opacity: 0.9; }

  .nav-links { display: flex; gap: 3rem; list-style: none; }
  .nav-links a {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text-muted);
    transition: 0.4s cubic-bezier(0.2, 1, 0.3, 1);
  }
  .nav-links a:hover { color: var(--text-linen); }

  /* ── HERO ── */
  .hero {
    height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding: 0 10%;
  }

  .hero-eyebrow {
    font-size: 0.6rem;
    color: var(--sage-glow);
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 100;
    line-height: 1;
    margin-bottom: 2.5rem;
    letter-spacing: -0.03em;
  }

  .hero-title em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--sage-glow);
    font-weight: 300;
  }

  .btn-minimal {
    display: inline-block;
    padding: 1.2rem 3rem;
    background: var(--text-linen);
    color: var(--bg-black);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: 0.5s;
  }

  .btn-minimal:hover {
    background: var(--sage-glow);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(138, 154, 91, 0.2);
  }

  /* ── CINEMATIC PLAYER (GLASS) ── */
  .reel-section {
    padding: 4rem 10%;
    margin-bottom: 6rem;
  }

  .glass-container {
    background: var(--glass-white);
    border: 1px solid var(--border-subtle);
    padding: 3rem;
    display: flex; gap: 5rem; align-items: center;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .glass-container::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.02), transparent);
    animation: shine 8s infinite;
  }

  @keyframes shine {
    0% { left: -100%; }
    20% { left: 100%; }
    100% { left: 100%; }
  }

  .vimeo-vertical {
    flex: 1;
    max-width: 320px;
    aspect-ratio: 9/16;
    background: #000;
    border: 1px solid var(--border-subtle);
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
  }

  /* ── GRID SYSTEM ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border-subtle);
    margin: 0 10% 8rem;
  }

  .service-item {
    background: var(--bg-black);
    padding: 4rem 3rem;
    transition: 0.4s;
  }

  .service-item:hover {
    background: var(--glass-white);
  }

  .service-num {
    font-family: var(--font-sans);
    font-weight: 100;
    font-size: 0.7rem;
    color: var(--sage-glow);
    margin-bottom: 2rem;
    display: block;
  }

  .service-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 1.5rem;
  }

  /* ── FOOTER ── */
  footer {
    padding: 6rem 4rem 3rem;
    text-align: center;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-logo {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  @media (max-width: 1000px) {
    nav { padding: 1.5rem 2rem; }
    .nav-links { display: none; }
    .glass-container { flex-direction: column; padding: 2rem; gap: 3rem; }
    .vimeo-vertical { width: 100%; max-width: 100%; }
  }
</style>
</head>
<body>

<div class="aura"></div>

<nav>
  <a href="#" class="nav-logo">
    <img src="logo.png" alt="Janloyd Visual">
  </a>
  <ul class="nav-links">
    <li><a href="#reel">Showreel</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="https://calendly.com/janloyd-visual/30min" class="btn-minimal" style="padding: 0.6rem 1.5rem; font-size: 0.6rem;">Book Call</a>
</nav>

<section class="hero">
  <div class="hero-eyebrow">Visual Curation for High-Ticket Real Estate</div>
  <h1 class="hero-title">
    Architecting<br>
    <em>Quiet</em> Luxury.
  </h1>
  <p style="max-width: 450px; color: var(--text-muted); font-weight: 300; font-size: 0.9rem; margin-bottom: 3rem;">
    Engineering cinematic narratives for the world’s most exclusive listings. A fusion of technical precision and minimalist soul.
  </p>
  <div class="hero-actions">
    <a href="#services" class="btn-minimal">Explore Protocols</a>
  </div>
</section>

<section id="reel" class="reel-section">
  <div class="glass-container">
    <div style="flex: 1.2;">
      <span class="hero-eyebrow" style="font-size: 0.5rem;">01 // MOTION_ASSET</span>
      <h2 style="font-family: var(--font-serif); font-size: 3rem; margin: 1.5rem 0 2rem; font-weight: 300; line-height: 1.1;">
        The Antidote to <em style="color: var(--sage-glow);">Visual Noise.</em>
      </h2>
      <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.8;">
        Flashy editing is a distraction. In luxury, the property is the protagonist. We utilize architectural pacing and "invisible" transitions to create a sanctuary-first viewing experience.
      </p>
    </div>
    <div class="vimeo-vertical">
      <iframe src="https://player.vimeo.com/video/1185096105?title=0&byline=0&portrait=0&badge=0&autopause=0&player_id=0&app_id=58479" 
              frameborder="0" 
              allow="autoplay; fullscreen; picture-in-picture" 
              style="width:100%;height:100%;" 
              title="Janloyd Visual Showreel">
      </iframe>
    </div>
  </div>
</section>

<section id="services" class="services-grid">
  <div class="service-item">
    <span class="service-num">P_01</span>
    <h3 class="service-title">Social Starter</h3>
    <p style="color: var(--text-muted); font-size: 0.8rem;">High-velocity cinematic reels for discovery.</p>
    <div style="margin-top: 2rem; font-size: 1.2rem; font-weight: 300;">$150 <span style="font-size: 0.6rem; color: var(--text-muted);">AUD</span></div>
  </div>
  <div class="service-item" style="border-left: 1px solid var(--border-subtle); border-right: 1px solid var(--border-subtle);">
    <span class="service-num">P_02</span>
    <h3 class="service-title">Listing Hero</h3>
    <p style="color: var(--text-muted); font-size: 0.8rem;">Full-immersion property films for high-intent buyers.</p>
    <div style="margin-top: 2rem; font-size: 1.2rem; font-weight: 300;">$350 <span style="font-size: 0.6rem; color: var(--text-muted);">AUD</span></div>
  </div>
  <div class="service-item">
    <span class="service-num">P_03</span>
    <h3 class="service-title">Retainer Partner</h3>
    <p style="color: var(--text-muted); font-size: 0.8rem;">Dedicated visual curation on a monthly cycle.</p>
    <div style="margin-top: 2rem; font-size: 1.2rem; font-weight: 300;">$600 <span style="font-size: 0.6rem; color: var(--text-muted);">AUD</span></div>
  </div>
</section>

<footer>
  <div class="footer-logo">Janloyd Visual // 2026</div>
  <p style="font-size: 0.5rem; color: var(--text-muted); margin-top: 1rem; letter-spacing: 0.1em;">PHILIPPINES // UK // USA // AUSTRALIA</p>
</footer>

</body>
</html>
